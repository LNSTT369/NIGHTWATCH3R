{
  "name": "valkyrie",
  "version": "0.1.0",
  "description": "Cloudflare Workers MCP server for autonomous stock trading with Alpaca",
  "type": "module",
  "scripts": {
    "dev": "npx wrangler dev",
    "build:ui": "vite build --config vite.portal.config.ts",
    "build": "npm run build:ui && npx tsc",
    "deploy": "npx wrangler deploy",
    "deploy:production": "npx wrangler deploy --env production",
    "start:os": "npx wrangler dev --port 8787 --local",
    "db:migrate": "npx wrangler d1 migrations apply valkyrie-db --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply valkyrie-db --remote",
    "db:studio": "npx wrangler d1 execute valkyrie-db --local --command 'SELECT 1'",
    "typecheck": "npx tsc --noEmit",
    "lint": "npx eslint src/",
    "test": "npx vitest",
    "test:run": "npx vitest run"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "agents": "^0.3.6",
    "clsx": "^2.1.1",
    "motion": "^12.0.0",
    "openai": "^6.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.0.18",
    "wrangler": "^4.61.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
